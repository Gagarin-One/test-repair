FROM node:18-alpine

WORKDIR /app

# Копируем package файлы
COPY package*.json ./

# Устанавливаем ВСЕ зависимости (включая TypeScript)
RUN npm install

# Копируем исходный код
COPY . .

# Собираем TypeScript
RUN npm run build

# Указываем порт
EXPOSE 3001

# Запускаем приложение
CMD ["node", "dist/index.js"]
